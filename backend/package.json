    "@types/express": "^5.0.3",
    "@types/node": "^20.17.57",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^3.2.4"
  }
